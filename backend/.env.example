# Copy this file to .env and adjust as needed.
# All values shown here are the defaults used when .env is absent.

HOST=0.0.0.0
PORT=8000

# Comma-separated list of allowed CORS origins (JSON array syntax)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Directory where per-job working files and output videos are stored.
# Created automatically on startup if it does not exist.
JOBS_DIR=./jobs

# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
